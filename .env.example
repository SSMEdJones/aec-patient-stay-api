# =============================================================================
# AWS Configuration (same as aec-mychart-qa-api)
# =============================================================================
# AWS credentials - using ~/.aws/credentials instead
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# LLM Provider: "bedrock", "azure", or "openai"
LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# =============================================================================
# Epic FHIR API Configuration
# =============================================================================
EPIC_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_CLIENT_ID=your-client-id
EPIC_CLIENT_SECRET=your-client-secret
EPIC_PRIVATE_KEY_PATH=./keys/epic_private_key.pem

# =============================================================================
# Azure OpenAI (alternative to Bedrock)
# =============================================================================
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# =============================================================================
# Langfuse LLM Observability (for drift/hallucination tracking)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://your-langfuse-instance.com

# =============================================================================
# OpenAI direct (alternative)
# =============================================================================
# OPENAI_API_KEY=your-openai-key

# =============================================================================
# Application Settings
# =============================================================================
# API Port (default: 8001 to avoid collision with mychart-qa on 8000)
API_PORT=8001
LOG_LEVEL=INFO
DEBUG_MODE=False
